// AWS Configuration for Public S3 Access
aws {
    region = 'us-east-1'
    client {
        anonymous = true // Critical: Allows access to public buckets
    }
}

params {
    // Ensure these match your script variables
    input_s3  = 's3://tiffimage/tiffimage/*.tif'
    outdir    = './results'
}

process {
    // Use the exact process name from your main.nf
    withName: 'CROP_AND_COMPRESS' {
        // Conda directive for dependency management
        conda = 'conda-forge::tifffile conda-forge::numpy conda-forge::imagecodecs'
    }
}

// Enable Conda support globally
conda.enabled = true
