aws {
    region = 'us-east-1' // Change to your bucket's region
    client {
        anonymous = true
    }
}

params {
    input_s3  = 's3://tiffimage/tiffimage/*.tif'
    outdir    = './results'
}

process {
    withName: 'CROP_AND_COMPRESS' {
        conda = 'conda-forge::tifffile conda-forge::numpy'
    }
}
