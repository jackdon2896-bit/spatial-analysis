#!/usr/bin/env python3
import sys
import tifffile as tf
import numpy as np

def process_scrna_tiff(input_path, output_path):
    # Load image - preserves 16-bit depth and multiple channels
    img = tf.imread(input_path)
    
    # scRNA-seq images are often (Channels, Y, X) or (Y, X, Channels)
    # Example: Crop a 1000x1000 region from the top-left
    # If 3D (C, Y, X): img[:, 0:1000, 0:1000]
    # If 2D (Y, X): img[0:1000, 0:1000]
    if img.ndim == 3:
        cropped = img[:, 0:1000, 0:1000]
    else:
        cropped = img[0:1000, 0:1000]
        
    # Save with lossless LZW or Adobe Deflate compression
    tf.imwrite(
        output_path, 
        cropped, 
        compression='zlib',  # Same as 'deflate', excellent for scientific data
        photometric='minisblack'
    )

if __name__ == "__main__":
    process_scrna_tiff(sys.argv[1], sys.argv[2])
