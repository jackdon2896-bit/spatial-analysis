#!/usr/bin/env python3
import sys
import tifffile as tf
import numpy as np

def process_scrna_tiff(input_path, output_path):
    # Load 16-bit scRNA-seq image
    img = tf.imread(input_path)
    
    # Simple crop: [Channels, Y, X] or [Y, X]
    # Example: Taking the first 2000x2000 pixels
    if img.ndim == 3:
        cropped = img[:, 0:2000, 0:2000]
    else:
        cropped = img[0:2000, 0:2000]
        
    # Save with lossless Deflate (zlib) compression to preserve gene signals
    tf.imwrite(
        output_path, 
        cropped, 
        compression='zlib',
        photometric='minisblack'
    )

if __name__ == "__main__":
    # Get filenames from Nextflow command line
    input_file = sys.argv[1]
    output_file = sys.argv[2]
    process_scrna_tiff(input_file, output_file)
